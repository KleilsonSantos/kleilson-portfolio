{
  "name": "kleilson-portfolio",
  "private": true,
  "version": "0.4.0",
  "description": "Portfólio profissional open source — Kleilson dos Santos",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently -k -n api,web -c cyan,magenta \"npm run server:dev\" \"API_PROXY=1 npm run dev\"",
    "server:dev": "tsx server/index.ts",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "typecheck:server": "tsc -p server/tsconfig.json",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lighthouse": "lhci autorun",
    "optimize:photo": "node scripts/optimize-profile-photo.mjs",
    "deploy:api": "wrangler deploy"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260711.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "sharp": "^0.35.3",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
