# =============================================================================
# kleilson-portfolio — template de ambiente (VERSIONADO, sem segredos)
# =============================================================================
# Uso:
#   cp .env.example .env
#   # edite .env com valores reais do Dashboard Supabase
#
# O arquivo .env NÃO é commitado (.gitignore). Sync com o remoto
# (git pull / merge / checkout) NÃO apaga o .env local — arquivos
# ignorados permanecem no disco.
#
# Produção: injete as mesmas chaves como secrets do host (#8), não via Git.
# =============================================================================

# --- Supabase projeto (API) ---------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Publishable (sb_publishable_…) — não é Personal Access Token (sbp_…)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-only — NUNCA prefixar com VITE_
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

SUPABASE_JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json

# --- Postgres / Drizzle -------------------------------------------------------
# Settings → Database → connection string (pooler, porta 6543).
# Substitua [YOUR-PASSWORD] pela senha real do banco.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres

# --- API Fastify (opcional) ---------------------------------------------------
# PORT=8787
# HOST=127.0.0.1
# CORS_ORIGIN=http://localhost:5173
# API_PROXY=1

# --- Frontend (build Pages) ---------------------------------------------------
# Só se a API NÃO estiver no mesmo origin do SPA (ADR-0008).
# Sem barra final. Ex.: https://api.example.com
# VITE_API_BASE_URL=