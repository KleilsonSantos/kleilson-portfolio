# =============================================================================
# kleilson-portfolio — template de ambiente (VERSIONADO, sem segredos)
# =============================================================================
# Uso:
#   cp .env.example .env
#   # edite .env com valores reais do Dashboard Supabase / OAuth App
#
# O arquivo .env NÃO é commitado (.gitignore). Sync com o remoto
# (git pull / merge / checkout) NÃO apaga o .env local.
#
# Ordem:
#   1–2  runtime local (API + DB)
#   3–6  opcionais (API/Vite/obs/analytics)
#   7    Decap OAuth (referência local + sync Wrangler)
#   8    ferramentas IDE/MCP (fora do runtime do site)
#
# Produção: secrets do host, não via Git.
#   Worker API:  wrangler secret put SUPABASE_URL | SUPABASE_SERVICE_ROLE_KEY | CORS_ORIGIN
#   Decap OAuth: wrangler secret put GITHUB_CLIENT_ID | GITHUB_CLIENT_SECRET | ADMIN_GITHUB_LOGINS
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Supabase — projeto (API / MCP / ops)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Publishable (sb_publishable_…) — não é Personal Access Token (sbp_…)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-only — NUNCA prefixar com VITE_
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Auth JWKS — validação JWT; não é senha do Postgres
SUPABASE_JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json

# -----------------------------------------------------------------------------
# 2. Postgres / Drizzle — API local (apps/api)
# -----------------------------------------------------------------------------
# Settings → Database → connection string (pooler, porta 6543).
# Substitua [YOUR-PASSWORD] pela senha real do banco.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres

# -----------------------------------------------------------------------------
# 3. API Fastify local (apps/api) — opcional; defaults no código
# -----------------------------------------------------------------------------
# PORT=8787
# HOST=127.0.0.1
# CORS_ORIGIN=http://localhost:5173
# API_PROXY=1
# API_PROXY_TARGET=http://127.0.0.1:8787
# RATE_LIMIT_MAX=30
# RATE_LIMIT_WINDOW=1 minute
# CONTACT_RATE_LIMIT_MAX=5
# CONTACT_RATE_LIMIT_WINDOW=1 minute
# LOG_LEVEL=info

# -----------------------------------------------------------------------------
# 4. Observabilidade (#9 / ADR-0009) — opcional; sem DSN = no-op
# -----------------------------------------------------------------------------
# VITE_SENTRY_DSN=https://...@o....ingest.sentry.io/...
# SENTRY_DSN=https://...@o....ingest.sentry.io/...

# -----------------------------------------------------------------------------
# 5. Analytics (#65 / ADR-0010) — opcional; sem URL+ID = no-op
# -----------------------------------------------------------------------------
# VITE_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
# VITE_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# VITE_UMAMI_DOMAINS=localhost,kleilson-portfolio.pages.dev

# -----------------------------------------------------------------------------
# 6. Frontend (build Pages / Vite) — opcional em local
# -----------------------------------------------------------------------------
# Só se a API NÃO estiver no mesmo origin (ADR-0008). Sem barra final.
# VITE_API_BASE_URL=https://kleilson-portfolio-api.kleilsonsantos.workers.dev

# -----------------------------------------------------------------------------
# 7. Decap OAuth (#71 / ADR-0012) — referência local + Wrangler (prod)
# -----------------------------------------------------------------------------
# Runtime prod: Worker `kleilson-decap-oauth` (wrangler secret put).
# Após preencher/rotacionar no .env, sincronize:
#   pnpm --filter @kleilson/decap-oauth exec wrangler secret put GITHUB_CLIENT_ID
#   pnpm --filter @kleilson/decap-oauth exec wrangler secret put GITHUB_CLIENT_SECRET
#   pnpm --filter @kleilson/decap-oauth exec wrangler secret put ADMIN_GITHUB_LOGINS
# Callback OAuth App: https://kleilson-decap-oauth.kleilsonsantos.workers.dev/callback
# GITHUB_CLIENT_ID=Ov23li...
# GITHUB_CLIENT_SECRET=
# ADMIN_GITHUB_LOGINS=KleilsonSantos

# -----------------------------------------------------------------------------
# 8. Ferramentas locais / MCP (Cursor) — fora do runtime do portfólio
# -----------------------------------------------------------------------------
# Não lidas por apps/web, apps/api, worker-api ou decap-oauth.
# HUGGINGFACE_API_KEY=hf_...
